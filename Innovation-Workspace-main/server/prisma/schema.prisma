generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model activity_log {
  id         Int       @id @default(autoincrement())
  user_name  String
  action     String
  project_id Int
  created_at DateTime? @default(now()) @db.Timestamp(6)
  projects   projects  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([project_id, created_at(sort: Desc)], map: "idx_activity_project_created")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model budget_entries {
  id                   Int       @id @default(autoincrement())
  project_id           Int
  item_name            String?   @default("")
  qty                  Decimal?  @db.Decimal(12, 2)
  vendor1_name         String?   @default("")
  vendor1_amount       Decimal?  @db.Decimal(12, 2)
  vendor2_name         String?   @default("")
  vendor2_amount       Decimal?  @db.Decimal(12, 2)
  vendor3_name         String?   @default("")
  vendor3_amount       Decimal?  @db.Decimal(12, 2)
  final_vendor_details String?   @default("")
  final_amount         Decimal?  @db.Decimal(12, 2)
  remarks              String?   @default("")
  po_number            String?   @default("")
  utr                  String?   @default("")
  transaction_date     DateTime? @db.Date
  transaction_amount   Decimal?  @db.Decimal(12, 2)
  invoice              String?   @default("")
  status               String?   @default("PENDING")
  invoice_qty          Decimal?  @db.Decimal(12, 2)
  invoice_date         DateTime? @db.Date
  certified_by         String?   @default("")
  created_at           DateTime? @default(now()) @db.Timestamp(6)
  updated_at           DateTime? @default(now()) @db.Timestamp(6)
  projects             projects  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([project_id], map: "idx_budget_project_id")
  @@index([project_id, status], map: "idx_budget_project_status")
}

model quotations {
  id          Int       @id @default(autoincrement())
  project_id  Int
  file_path   String
  file_name   String
  vendor_name String?   @default("")
  notes       String?   @default("")
  uploaded_by String
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  projects    projects  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([project_id, created_at(sort: Desc)], map: "idx_quotations_project_created")
}

model budgets {
  id          Int       @id @default(autoincrement())
  project_id  Int
  category    String
  amount      Decimal   @db.Decimal(10, 2)
  notes       String?
  status      String?   @default("PENDING")
  created_by  String
  approved_at DateTime? @db.Timestamp(6)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  projects    projects  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([project_id], map: "idx_budgets_project")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model documents {
  id          Int       @id @default(autoincrement())
  project_id  Int
  filename    String
  file_path   String
  type        String
  size        Int?
  uploaded_by String
  status      String?   @default("PENDING")
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  projects    projects  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([project_id], map: "idx_documents_project")
}

model notifications {
  id         Int       @id @default(autoincrement())
  user_id    Int
  message    String
  read       Boolean?  @default(false)
  project_id Int?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  projects   projects? @relation(fields: [project_id], references: [id], onUpdate: NoAction)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_notifications_created_at")
  @@index([user_id, read], map: "idx_notifications_user_read")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model projects {
  id                Int              @id @default(autoincrement())
  name              String
  description       String?          @default("")
  mentor            String
  department        String
  progress          Int?             @default(0)
  team_count        Int?             @default(1)
  team_members_json Json?            @default("[]") @map("team_members")
  due_date          DateTime?        @db.Date
  accent            String?
  created_at        DateTime?        @default(now()) @db.Timestamp(6)
  activity_log      activity_log[]
  budget_entries    budget_entries[]
  budgets           budgets[]
  documents         documents[]
  notifications     notifications[]
  reports           reports[]
  tasks             tasks[]
  team_members      team_members[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reports {
  id             Int       @id @default(autoincrement())
  project_id     Int
  user_name      String
  type           String
  content        String
  status         String?   @default("PENDING")
  mentor_comment String?
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  approved_at    DateTime? @db.Timestamp(6)
  projects       projects  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([project_id], map: "idx_reports_project_id")
  @@index([project_id, type], map: "idx_reports_project_type")
  @@index([status], map: "idx_reports_status")
}

model task_attachments {
  id          Int       @id @default(autoincrement())
  task_id     Int
  filename    String
  file_path   String
  size        Int?
  uploaded_by String
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  tasks       tasks     @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([task_id], map: "idx_task_attachments_task")
}

model task_comments {
  id          Int       @id @default(autoincrement())
  task_id     Int
  author      String
  author_role String
  text        String
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  tasks       tasks     @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([task_id], map: "idx_task_comments_task")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model tasks {
  id               Int                @id @default(autoincrement())
  title            String
  status           String
  task_type        String?            @default("weekly")
  created_by       String?            @default("")
  description      String?            @default("")
  due_date         DateTime?          @db.Date
  assignee         String?            @default("")
  comments         Json?              @default("[]")
  approval_status  String?            @default("not-requested")
  mentor_note      String?            @default("")
  order_index      Int?               @default(0)
  updated_at       DateTime?          @default(now()) @db.Timestamp(6)
  project_id       Int
  task_attachments task_attachments[]
  task_comments    task_comments[]
  projects         projects           @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([project_id], map: "idx_tasks_project_id")
  @@index([project_id, status], map: "idx_tasks_project_status")
}

model team_members {
  id         Int       @id @default(autoincrement())
  project_id Int
  user_id    Int?
  name       String
  usn        String
  email      String?
  photo      String?
  role       String    @default("student")
  joined_at  DateTime? @default(now()) @db.Timestamp(6)
  projects   projects  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User?     @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@unique([project_id, usn])
  @@index([project_id], map: "idx_team_members_project")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model User {
  id            Int             @id @default(autoincrement())
  name          String
  email         String          @unique
  passwordHash  String          @map("password_hash")
  role          String          @default("student")
  createdAt     DateTime?       @default(now()) @map("created_at") @db.Timestamp(6)
  notifications notifications[]
  teamMembers   team_members[]

  @@map("users")
}
